# ── TEL — .gitignore ──────────────────────────────────────────────────────────

# ── CRITICAL: Environment & secrets ──────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
/.pnp
.pnp.js

# ── Next.js ───────────────────────────────────────────────────────────────────
/.next/
/out/
.vercel
.netlify

# ── Build outputs ─────────────────────────────────────────────────────────────
/dist/
/build/
*.tsbuildinfo
next-env.d.ts

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
/logs/

# ── Test / coverage ───────────────────────────────────────────────────────────
/coverage/
.nyc_output/
junit.xml

# ── Supabase local (Phase 2) ──────────────────────────────────────────────────
.supabase/
supabase/.branches/
supabase/.temp/

# ── Misc ──────────────────────────────────────────────────────────────────────
.turbo/
.cache/
