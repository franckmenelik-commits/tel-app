# TEL — The Experience Layer
# Copiez ce fichier en .env.local et remplissez vos valeurs
# Exécutez "npm run check-souffle" pour vérifier quels niveaux sont actifs

# ─── SOUFFLE NIVEAU 1 — L'ÉCOUTE (Ollama local) ──────────────────────────────
# Gratuit, souverain. Installez Ollama + tirez le modèle :
#   brew install ollama
#   ollama pull mistral
# Ollama démarre automatiquement sur localhost:11434

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ─── SOUFFLE NIVEAU 2 — LA TRAVERSÉE (Mistral API) ───────────────────────────
# Croisements profonds, 3+ sources, contextes culturels complexes
# https://console.mistral.ai/

MISTRAL_API_KEY=

# ─── SOUFFLE NIVEAU 3 — LA RÉVÉLATION (Claude Anthropic) ─────────────────────
# L'indicible en langage, vécus fragiles, langues en danger, cas institutionnels
# https://console.anthropic.com/

ANTHROPIC_API_KEY=

# ─── APPLICATION ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=https://theexperiencelayer.org

# ─── PHASE 2 — Supabase (préparé, pas encore connecté) ───────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
