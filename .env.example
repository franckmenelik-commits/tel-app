# ─── TEL — The Experience Layer ───────────────────────────────────────────────
# Copiez ce fichier en .env.local et remplissez vos valeurs
# Exécutez "npm run check-souffle" pour vérifier quels niveaux SOUFFLE sont actifs

# ─── SOUFFLE NIVEAU 1 — L'ÉCOUTE (Ollama local) ──────────────────────────────
# Gratuit, souverain. Installez Ollama + tirez le modèle :
#   brew install ollama && ollama pull mistral
# Ollama démarre automatiquement sur localhost:11434

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ─── SOUFFLE NIVEAU 2 — LA TRAVERSÉE (Mistral API) ───────────────────────────
# Croisements profonds, 3+ sources, contextes culturels complexes
# https://console.mistral.ai/

MISTRAL_API_KEY=

# ─── SOUFFLE NIVEAU 3 — LA RÉVÉLATION (Claude Anthropic) ─────────────────────
# L'indicible en langage, vécus fragiles, langues en danger, cas institutionnels
# https://console.anthropic.com/

ANTHROPIC_API_KEY=

# ─── Whisper — Transcription YouTube (Plan B) ─────────────────────────────────
# Optionnel. Si défini, TEL utilise cet endpoint pour transcrire les vidéos YouTube
# quand youtube-transcript (Plan A) échoue.
# Format : http://YOUR_SERVER_IP:9000
# Laissez vide pour ignorer le Plan B (Plan C metadata fallback s'active à la place)

WHISPER_ENDPOINT=

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
# Optionnel. Utilisé dans auto-search (mode keyword) pour trouver des vidéos.
# Sans cette clé, TEL utilise yt-search (pas d'API key, plus lent).
# https://console.cloud.google.com/

YOUTUBE_API_KEY=

# ─── Semantic Scholar API ─────────────────────────────────────────────────────
# Optionnel. Utilisé dans l'enrichissement automatique (Niveau 2) pour les sources académiques.
# Sans cette clé, la recherche Semantic Scholar est ignorée gracieusement.
# https://www.semanticscholar.org/product/api

SEMANTIC_SCHOLAR_API_KEY=

# ─── APPLICATION ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=https://theexperiencelayer.org

# ─── Analytics (optionnel) ────────────────────────────────────────────────────
# Umami analytics site ID — laissez vide pour désactiver

NEXT_PUBLIC_UMAMI_SITE_ID=

# ─── PHASE 2 — Base de connaissances vectorielle (préparé, pas encore connecté) ─
# Pinecone — stockage des embeddings de la base de sagesse TEL
# https://www.pinecone.io/ — Index: tel-wisdom, dimension: 1536

PINECONE_API_KEY=

# ─── Seed endpoint — Protection admin ────────────────────────────────────────
# Clé secrète pour déclencher le seeding via POST /api/seed
# Header requis : x-admin-key: <valeur>
# Générez une clé aléatoire : openssl rand -base64 32

ADMIN_SECRET=

# Exa.ai — recherche sémantique (par sens, pas par mots-clés)
# Utilisé pour découvrir des sources qui "résonnent" avec une requête
# https://exa.ai/

EXA_API_KEY=

# ─── PHASE 2 — Supabase pgvector (préparé, pas encore connecté) ───────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
